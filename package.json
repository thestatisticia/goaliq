{
  "name": "goaliq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-ports.js",
    "prebuild": "node scripts/kill-ports.js",
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:x402\"",
    "dev:clean": "node scripts/kill-ports.js && node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "dev:next": "next dev",
    "dev:x402": "tsx watch server/x402-server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@cosmjs/encoding": "^0.39.0",
    "@injectivelabs/x402": "0.0.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "next": "^14.2.22",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
