# API-Football (fallback — predictions + backup when football-data unavailable)
# When one key hits the 100 req/day limit, the next key is used automatically.
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_KEY_2=your_second_api_key_here

# football-data.org (primary — 10 req/min, full WC 2026 season in 1-2 calls)
# Register free at https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your_football_data_key_here

# World Cup identifiers (API-Football)
WC_LEAGUE_ID=1
WC_SEASON=2026

# Next.js app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Injective network for Keplr (testnet | mainnet)
NEXT_PUBLIC_INJECTIVE_NETWORK=testnet

# x402 premium API server (runs separately on port 3001)
NEXT_PUBLIC_X402_API_URL=http://localhost:3001
X402_FACILITATOR_URL=https://x402.injective.network
X402_PORT=3001

# Injective network: testnet | mainnet
INJECTIVE_NETWORK=testnet

# Optional: Free AI models for CupCopilot (get one — both free, no credit card)
# Groq: https://console.groq.com/keys  (recommended — fast, 14k req/day)
GROQ_API_KEY=

# Google Gemini: https://aistudio.google.com/apikey  (1,500 req/day)
GEMINI_API_KEY=

# Treasury wallet that receives 0.01 USDC premium payments (must differ from your Keplr wallet)
NEXT_PUBLIC_PAYMENT_WALLET=0x000000000000000000000000000000000000dEaD
